{
  "name": "bilive-danmaku",
  "productName": "bilive-danmaku",
  "version": "1.0.11",
  "ElectronReactVersion": "1.1.0",
  "packageManager": "pnpm@10.22.0",
  "description": "bilibili live danmaku client",
  "scripts": {
    "start": "ts-node ./.erb/scripts/check-port-in-use.js && pnpm build:dll && pnpm start:renderer",
    "start:main": "cross-env NODE_ENV=development electron -r ts-node/register/transpile-only ./src/main/main.ts",
    "start:renderer": "cross-env NODE_ENV=development TS_NODE_TRANSPILE_ONLY=true webpack serve --config ./.erb/configs/webpack.config.renderer.dev.ts",
    "build": "concurrently \"pnpm build:main\" \"pnpm build:renderer\"",
    "build:main": "cross-env NODE_ENV=production TS_NODE_TRANSPILE_ONLY=true webpack --config ./.erb/configs/webpack.config.main.prod.ts",
    "build:renderer": "cross-env NODE_ENV=production TS_NODE_TRANSPILE_ONLY=true webpack --config ./.erb/configs/webpack.config.renderer.prod.ts",
    "build:dll": "cross-env NODE_ENV=development TS_NODE_TRANSPILE_ONLY=true webpack --config ./.erb/configs/webpack.config.renderer.dev.dll.ts",
    "rebuild": "electron-rebuild --parallel --types prod,dev,optional --module-dir release/app",
    "package": "ts-node ./.erb/scripts/clean.js dist && pnpm build && electron-builder build --publish never",
    "test": "jest"
  },
  "build": {
    "productName": "bilive-danmaku",
    "appId": "com.github.Beats0.bilive-danmaku",
    "asar": true,
    "asarUnpack": "**\\*.{node,dll}",
    "files": [
      "dist",
      "node_modules",
      "package.json"
    ],
    "mac": {
      "target": {
        "target": "default",
        "arch": [
          "arm64",
          "x64"
        ]
      },
      "type": "distribution",
      "hardenedRuntime": true,
      "entitlements": "assets/entitlements.mac.plist",
      "entitlementsInherit": "assets/entitlements.mac.plist",
      "gatekeeperAssess": false
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Development"
    },
    "nsis": {
      "deleteAppDataOnUninstall": true
    },
    "directories": {
      "app": "release/app",
      "buildResources": "assets",
      "output": "release/build"
    },
    "extraResources": [
      "./assets/**",
      "./extraResources/**"
    ],
    "publish": {
      "provider": "github",
      "owner": "Beats0",
      "repo": "bilive-danmaku"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Beats0/bilive-danmaku.git"
  },
  "author": {
    "name": "Beats0",
    "email": "Beats01998@gmail.com",
    "url": "https://github.com/Beats0"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Beats0/bilive-danmaku/issues"
  },
  "keywords": [
    "electron",
    "bilibili",
    "bilibili live"
  ],
  "homepage": "https://github.com/Beats0/bilive-danmaku#readme",
  "jest": {
    "testURL": "http://localhost/",
    "testEnvironment": "jsdom",
    "transform": {
      "\\.(ts|tsx|js|jsx)$": "ts-jest"
    },
    "moduleNameMapper": {
      "\\.(jpg|jpeg|png|gif|eot|otf|webp|svg|ttf|woff|woff2|mp4|webm|wav|mp3|m4a|aac|oga)$": "<rootDir>/.erb/mocks/fileMock.js",
      "\\.(css|less|sass|scss)$": "identity-obj-proxy"
    },
    "moduleFileExtensions": [
      "js",
      "jsx",
      "ts",
      "tsx",
      "json"
    ],
    "moduleDirectories": [
      "node_modules",
      "release/app/node_modules"
    ],
    "testPathIgnorePatterns": [
      "release/app/dist"
    ]
  },
  "devDependencies": {
    "@pmmmwh/react-refresh-webpack-plugin": "0.5.4",
    "@teamsupercell/typings-for-css-modules-loader": "^2.5.2",
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^12.1.5",
    "@types/configstore": "^5.0.1",
    "@types/electron-settings": "^4.0.2",
    "@types/jest": "^27.5.2",
    "@types/node": "17.0.5",
    "@types/pako": "^1.0.7",
    "@types/qs": "^6.15.0",
    "@types/react": "^17.0.91",
    "@types/react-dom": "^17.0.26",
    "@types/react-test-renderer": "^17.0.9",
    "@types/styled-components": "^5.1.36",
    "@types/terser-webpack-plugin": "^5.2.0",
    "@types/webpack-env": "^1.18.8",
    "browserslist-config-erb": "^0.0.3",
    "chalk": "^4.1.2",
    "concurrently": "^6.5.1",
    "core-js": "^3.49.0",
    "cross-env": "^7.0.3",
    "css-loader": "^6.11.0",
    "css-minimizer-webpack-plugin": "^3.4.1",
    "detect-port": "^1.6.1",
    "electron": "^26.6.10",
    "electron-builder": "^24.13.3",
    "electron-devtools-installer": "^3.2.1",
    "electron-rebuild": "^3.2.9",
    "file-loader": "^6.2.0",
    "html-webpack-plugin": "^5.6.7",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^27.5.1",
    "mini-css-extract-plugin": "^2.10.2",
    "react-refresh": "^0.11.0",
    "react-refresh-typescript": "^2.0.12",
    "react-test-renderer": "^17.0.2",
    "rimraf": "^3.0.2",
    "sass": "^1.99.0",
    "sass-loader": "^12.6.0",
    "style-loader": "^3.3.4",
    "terser-webpack-plugin": "^5.4.0",
    "ts-jest": "^27.1.5",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.2",
    "typescript": "^4.9.5",
    "url-loader": "^4.1.1",
    "webpack": "^5.106.2",
    "webpack-bundle-analyzer": "^4.10.2",
    "webpack-cli": "^4.10.0",
    "webpack-dev-server": "^4.15.2",
    "webpack-merge": "^5.10.0"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^6.7.2",
    "@hot-loader/react-dom": "^17.0.2",
    "@reduxjs/toolkit": "^1.9.7",
    "configstore": "^6.0.0",
    "electron-debug": "^3.2.0",
    "electron-log": "^4.4.8",
    "electron-settings": "^4.0.4",
    "electron-updater": "^6.8.3",
    "font-list": "^1.6.0",
    "history": "^5.3.0",
    "i18next": "^21.10.0",
    "i18next-browser-languagedetector": "^6.1.8",
    "md5": "^2.3.0",
    "node-fetch": "^3.3.2",
    "qrcode.react": "^4.2.0",
    "qs": "^6.15.1",
    "rc-dropdown": "^3.6.2",
    "rc-menu": "^9.16.1",
    "rc-notification": "^4.6.1",
    "rc-tooltip": "^5.3.1",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "react-i18next": "^11.18.6",
    "react-redux": "^7.2.9",
    "react-router-dom": "^6.30.3",
    "react-spring": "^9.7.5",
    "redux": "^4.2.1",
    "semver": "^7.7.4",
    "styled-components": "^5.3.11"
  },
  "browserslist": [],
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "sharp"
    ]
  }
}
